################################
##       RECETAS
################################

### GET - Listar todas las recetas
GET http://localhost:3000/api/receta


### POST - Crear receta
POST http://localhost:3000/api/receta HTTP/1.1
Content-Type: application/json

{
  "cita_id": 2, 
  "medicamento": "Omeprazol", 
  "dosis": "200mg", 
  "instruccion": "20mg cada 2 horas", 
  "fecha_emision": "2024-03-01"
}

### PUT - Actualizar Receta

PUT http://localhost:3000/api/receta
Content-Type: application/json

{
    "id": 61,
    "cita_id": 2,
    "medicamento": "paracetamol",
    "dosis": "200mg",
    "instruccion": "20mg cada 2 horas",
    "fecha_emision": "2024-03-01T05:00:00.000Z"
 }

### DELETE - Eliminar receta
DELETE http://localhost:3000/api/receta HTTP/1.1
Content-Type: application/json

{
    "id": 61
}























