













################################
##       PACIENTES
################################

### GET - Listar todos los pacientes
GET http://localhost:3000/api/paciente

### POST - Crear paciente
POST http://localhost:3000/api/paciente HTTP/1.1
Content-Type: application/json

{
  "nombre": "Pruebaasda",
  "correo": "prueba@pruebiasdta.com",
  "telefono": "30081101023",
  "fecha_nacimiento": "1981-10-23",
  "fecha_registro": "2024-02-08 11:30:00"
}

### PUT - Actualizar paciente
PUT http://localhost:3000/api/paciente
Content-Type: application/json

{
  "id": 5,
  "nombre": "Juanes",
  "correo": "juanes@email.com",
  "telefono": "3008110032",
  "fecha_nacimiento": "1990-01-15",
  "fecha_registro": "2024-01-20"
}

### DELETE - Eliminar paciente
DELETE http://localhost:3000/api/paciente HTTP/1.1
Content-Type: application/json

{
    "id": 1
}

















################################
##       CITAS
################################

### GET - Listar todas las citas
GET http://localhost:3000/api/cita

### POST - Crear cita
POST http://localhost:3000/api/cita HTTP/1.1
Content-Type: application/json

{
  "paciente_id": 1,
  "doctor_id": 2, 
  "fecha": "2024-03-01", 
  "hora": "09:00:00", 
  "motivo_consulta": "Control de presión arterial", 
  "estado": "realizada"
}

### PUT - Actualizar cita
PUT http://localhost:3000/api/cita
Content-Type: application/json

    {
        "id": 121,
        "paciente_id": 1,
        "doctor_id": 1,
        "fecha": "2024-03-01T05:00:00.000Z",
        "hora": "09:00:00",
        "motivo_consulta": "Control de potro",
        "estado": "realizada"
    }



### DELETE - Eliminar cita
DELETE http://localhost:3000/api/cita HTTP/1.1
Content-Type: application/json

{
    "id": 1
}

















################################
##       DOCTOR
################################

### GET - Listar todos los doctores
GET http://localhost:3000/api/doctor

### POST - Crear doctor
POST http://localhost:3000/api/doctor HTTP/1.1
Content-Type: application/json

{
  "nombre": "Prueba" ,
  "correo": "prueba@doctor.com",
  "telefono": 1234567899,
  "numero_consultorio": 1234567654
}

### PUT - Actualizar doctor
PUT http://localhost:3000/api/doctor
Content-Type: application/json

{
    "id": 1,
    "nombre": "Dr. Carlos Ramírez",
    "correo": "j.ramirez@cliniaca.com",
    "telefono": "3001234567",
    "numero_consultorio": 101
}

### DELETE - Eliminar doctor
DELETE http://localhost:3000/api/doctor HTTP/1.1
Content-Type: application/json

{
    "id": 1
}

















################################
##       ESPECIALIDAD
################################

### GET - Listar todas las especialidades
GET http://localhost:3000/api/especialidad

### POST - Crear especialidad
POST http://localhost:3000/api/especialidad HTTP/1.1
Content-Type: application/json

{
  "nombre": "Prueba" ,
  "descripcion": "Cirujano maxilofacial"
}

### PUT - Actualizar Especialidad

PUT http://localhost:3000/api/especialidad
Content-Type: application/json

{
    "id": 1,
    "nombre": "Cardiocirugua",
    "descripcion": "Especialidad dedicada al diagnóstico y tratamiento de enfermedades del corazón y del sistema circulatorio"
}

### DELETE - Eliminar especialidad
DELETE http://localhost:3000/api/especialidad HTTP/1.1
Content-Type: application/json

{
    "id": 11
}

















